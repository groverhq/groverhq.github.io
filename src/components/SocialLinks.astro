  googlebusiness:
    '<path d="M4 3h16l2 6H2l2-6zm0 8h16v10H4V11z" />',
};
---

<div class="flex flex-col gap-4">
  <!-- Row 1: First 5 icons -->
  <div class="flex flex-wrap gap-3">
    {
      links.slice(0, 5).map((link) => (
        <a
          href={link.url}
          class={`flex items-center justify-center rounded-full ${sizeClasses[size]} ${bgClasses[variant]} transition transform hover:scale-105`}
          target="_blank"
          rel="noopener"
          aria-label={link.ariaLabel}
        >
          <svg
            class={`${iconSizeClasses[size]} ${textClasses[variant]}`}
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <Fragment set:html={icons[link.icon]} />
          </svg>
        </a>
      ))
    }
  </div>

  <!-- Row 2: Remaining icons -->
  {
    links.length > 5 && (
      <div class="flex flex-wrap gap-3">
        {links.slice(5).map((link) => (
          <a
            href={link.url}
            class={`flex items-center justify-center rounded-full ${sizeClasses[size]} ${bgClasses[variant]} transition transform hover:scale-105`}
            target="_blank"
            rel="noopener"
            aria-label={link.ariaLabel}
          >
            <svg
              class={`${iconSizeClasses[size]} ${textClasses[variant]}`}
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <Fragment set:html={icons[link.icon]} />
            </svg>
          </a>
        ))}
      </div>
    )
  }
</div>
