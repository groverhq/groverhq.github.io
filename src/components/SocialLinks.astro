---
import { SOCIAL_LINKS } from "../config";

interface Props {
  size?: "sm" | "md" | "lg";
  variant?: "light" | "dark";
  excludeWhatsApp?: boolean;
  maxItems?: number;
}

const {
  size = "md",
  variant = "dark",
  excludeWhatsApp = false,
  maxItems,
} = Astro.props;

let links = SOCIAL_LINKS;

if (excludeWhatsApp) {
  links = links.filter((link) => link.name !== "WhatsApp");
}

if (maxItems) {
  links = links.slice(0, maxItems);
}

const sizeClasses = {
  sm: "w-8 h-8",
  md: "w-10 h-10",
  lg: "w-12 h-12",
};

const iconSizeClasses = {
  sm: "w-4 h-4",
  md: "w-5 h-5",
  lg: "w-6 h-6",
};

const bgClasses = {
  light: "bg-neutral-200 hover:bg-neutral-300",
  dark: "bg-neutral-800 hover:bg-neutral-700",
};

const textClasses = {
  light: "text-neutral-800",
  dark: "text-neutral-300",
};

// SVG icons mapping
