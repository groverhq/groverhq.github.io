---
import BannerTall from "../assets/banner-tall.png"; // your banner
---

<section
  id="work"
  class="bg-white py-24 px-6 lg:px-12 border-t border-gray-200"
>
  <div class="max-w-6xl mx-auto">
    <!-- Heading -->
    <div class="text-center mb-16">
      <h2 class="text-3xl lg:text-5xl font-bold mb-4">Our Work</h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        A growing collection of clean, fast, and scalable digital products built
        with precision and care.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Project 1: GroverHQ -->
      <div class="group">
        <h3 class="text-2xl font-semibold mb-2">GroverHQ Website</h3>
        <p class="text-gray-700 mb-4">
          A fast, modern, founder‑led agency website built with clean UI,
          scalable architecture, and a conversion‑focused layout.
        </p>

        <ul class="text-gray-600 text-sm space-y-1 mb-4">
          <li>• Built with Astro, Tailwind, and modern best practices</li>
          <li>• Fully responsive with premium UI/UX</li>
          <li>• Designed for trust, credibility, and conversions</li>
        </ul>

        <!-- Lighthouse Scores -->
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-8">
          <h3 class="text-xl font-semibold mb-4">Performance Audit</h3>
          <p class="text-gray-600 mb-6">
            Our site is built for speed, clarity, and accessibility — and it
            shows. Here's how GroverHQ scores on Google's Lighthouse audit:
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
            <div>
              <div class="text-3xl font-bold text-green-600">97</div>
              <div class="text-sm text-gray-500">Performance</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-green-600">100</div>
              <div class="text-sm text-gray-500">Accessibility</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-green-600">96</div>
              <div class="text-sm text-gray-500">Best Practices</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-green-600">100</div>
              <div class="text-sm text-gray-500">SEO</div>
            </div>
          </div>

          <p class="text-gray-500 text-sm mt-4">
            Audited with Google Lighthouse, March 2026.
          </p>
        </div>

        <div class="mt-4">
          <a
            href="https://groverhq.com"
            target="_blank"
            class="text-black font-medium text-lg underline hover:opacity-70 transition"
          >
            Visit Project →
          </a>
        </div>
      </div>

      <!-- Placeholder for future projects -->
      <div
        class="flex flex-col justify-center text-center border border-dashed border-gray-300 rounded-xl p-10"
      >
        <h3 class="text-xl font-semibold mb-3">Your Project Could Be Next</h3>
        <p class="text-gray-600 mb-6">
          Want to be our next featured case study? Let’s build something
          exceptional together.
        </p>
        <a
          href="#contact"
          class="text-black font-medium text-xl underline hover:opacity-70 transition"
        >
          Start a Project
        </a>
      </div>
    </div>
  </div>
</section>
