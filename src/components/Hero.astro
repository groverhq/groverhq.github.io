---
import LogoTagline from "../assets/logo-tagline.png"; // your banner
---

<section class="bg-neutral-950 text-white py-24 px-6 lg:px-12">
  <div
    class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center justify-between gap-12"
  >
    <!-- LEFT TEXT -->
    <div class="max-w-xl space-y-6">
      <h1 class="text-4xl lg:text-6xl font-bold leading-tight">
        Digital Solutions for <span class="text-neutral-300"
          >Modern Businesses</span
        >
      </h1>

      <p class="text-neutral-400 text-lg leading-relaxed">
        GroverHQ builds fast, scalable, and beautifully crafted digital
        experiences. From websites to automation, we help businesses grow with
        clean, modern technology.
      </p>

      <div class="flex gap-4 pt-4">
        <a
          href="#contact"
          class="px-6 py-3 bg-white text-black rounded-md font-medium hover:bg-neutral-200 transition"
        >
          Start a Project
        </a>

        <a
          href="#work"
          class="px-6 py-3 border border-neutral-700 rounded-md font-medium hover:border-neutral-500 transition"
        >
          View Work
        </a>
      </div>

      <!-- Social strip -->
      <div class="flex items-center gap-4 pt-6 text-neutral-400 ">
        <span class="text-lg text-base font-medium">
          Follow us on
        </span>

        <div class="flex items-center gap-4">
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/company/groverhq"
            class="flex items-center gap-1 hover:text-white transition"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7.5 0h3.8v2.2h.1c.5-.9 1.7-2.2 3.7-2.2 4 0 4.7 2.6 4.7 6V24h-4v-7.8c0-1.9 0-4.3-2.6-4.3-2.6 0-3 2-3 4.1V24h-4V8z"
              ></path>
            </svg>
            <span class="hidden sm:inline">LinkedIn</span>
          </a>

          <!-- GitHub -->
          <a
            href="https://github.com/groverhq"
            class="flex items-center gap-1 hover:text-white transition"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 .5C5.65.5.5 5.65.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.2-1.2-1.5-1.2-1.5-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 .1.8-.8.8-.8-.8-.1-1.6-.4-2.2-.9-1.7-1.4-1.7-4.1-.1-5.6.5-.5 1.2-.8 1.9-.9-.1-.2-.1-.5-.1-.8 0-1.1.9-2 2-2 .6 0 1.2.3 1.6.7.4-.1.8-.2 1.2-.2s.8.1 1.2.2c.4-.4 1-.7 1.6-.7 1.1 0 2 .9 2 2 0 .3 0 .6-.1.8.7.1 1.4.4 1.9.9 1.6 1.5 1.6 4.2-.1 5.6-.6.5-1.4.8-2.2.9 0 0-.2.9.8.8 0 0 .6-1.1 1.7-1.2 0 0 1.1 0 .1.7 0 0-.7.3-1.2 1.5 0 0-.7 2.1-3.9 1.4v2c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.65 18.35.5 12 .5z"
              ></path>
            </svg>
            <span class="hidden sm:inline">GitHub</span>
          </a>

          <!-- Twitter/X -->
          <a
            href="https://x.com/Grover_HQ"
            class="flex items-center gap-1 hover:text-white transition"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M18.9 1.5h3.2l-7 8 8.2 11h-6.4l-5-6.6-5.7 6.6H.9l7.5-8.7L.6 1.5h6.6l4.5 6 5.2-6z"
              ></path>
            </svg>
            <span class="hidden sm:inline">Twitter</span>
          </a>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/919878236480"
            class="flex items-center gap-1 hover:text-white transition"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M20.5 3.5A11.8 11.8 0 0012 0C5.4 0 0 5.4 0 12c0 2.1.6 4.1 1.6 5.8L0 24l6.3-1.6A12 12 0 0012 24c6.6 0 12-5.4 12-12 0-3.2-1.3-6.2-3.5-8.5z"
              ></path>
            </svg>
            <span class="hidden sm:inline">WhatsApp</span>
          </a>
        </div>
      </div>
    </div>

    <!-- RIGHT SIDE (LOGO + TAGLINE BANNER) -->
    <div
      class="flex justify-center lg:justify-end pl-0 lg:pl-12 w-full lg:flex-[0_0_50%]"
    >
      <img
        src={LogoTagline.src}
        alt="GroverHQ Banner"
        class="w-full max-w-xl lg:max-w-3xl xl:max-w-5xl"
      />
    </div>
  </div>
</section>
